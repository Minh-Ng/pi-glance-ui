{
  "name": "pi-glance-ui",
  "version": "0.2.0",
  "type": "module",
  "description": "At-a-glance recent-action and thinking renderers for Pi",
  "author": "Minh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Minh-Ng/pi-glance-ui.git"
  },
  "homepage": "https://github.com/Minh-Ng/pi-glance-ui#readme",
  "bugs": {
    "url": "https://github.com/Minh-Ng/pi-glance-ui/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "terminal-ui",
    "glance-ui"
  ],
  "files": [
    "src",
    "scripts",
    "docs",
    "media",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "pi": {
    "extensions": [
      "./src/index.js"
    ],
    "image": "https://raw.githubusercontent.com/Minh-Ng/pi-glance-ui/main/media/screenshot.png"
  },
  "scripts": {
    "benchmark:start": "GLANCE_UI_BENCHMARK=1 node --test --test-name-pattern='startup render benchmark' test/glance-ui.test.js",
    "check": "node scripts/check.mjs",
    "test": "node --test test/*.test.js",
    "prepublishOnly": "npm run check && npm test"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6"
  }
}
